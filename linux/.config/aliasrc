# Shared Aliases

# Section: Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

if command -v zoxide &> /dev/null; then
    alias cd='z'
    alias cdi='zi'
fi

if command -v eza &> /dev/null; then
    _eza_opts="--color=auto --icons=always --group-directories-first"
    alias ls="eza ${_eza_opts}"
    alias ll="eza -alF ${_eza_opts}"
    alias la="eza -A ${_eza_opts}"
    alias l="eza -CF ${_eza_opts}"
    alias tree="eza --tree ${_eza_opts}"
else
    alias ls='ls --color=auto'
    alias ll='ls -alF --color=auto'
    alias la='ls -A --color=auto'
    alias l='ls -CF --color=auto'
fi

# Section: Modern Tool Replacements
if command -v batcat &> /dev/null; then
    alias bat='batcat'
    alias cat='batcat'
    alias catp='batcat -p'
elif command -v bat &> /dev/null; then
    alias bat='bat'
    alias cat='bat'
    alias catp='bat -p'
fi

alias nf='fastfetch'
alias fetch='nf'
alias tldr='tldr'
alias du='dust'

# Section: Git Flow
alias g='git'
alias gs='git status'
alias gst='git status'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit -m'
alias gcm='git commit -m'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gds='git diff --staged'
alias glg="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all"

# Section: System
alias c='clear'
alias cls='clear'
alias h='history'
alias df='df -h'
alias free='free -m'
alias ports='netstat -tulanp'
alias myip='curl -s https://ifconfig.me && echo'
alias killport='fuser -k -n tcp'
alias sync='~/Dev/dotfiles/linux/install.sh'
alias reloadzsh='source $ZDOTDIR/.zshrc'
alias zshrc='${EDITOR:-nano} $ZDOTDIR/.zshrc'

# Section: Kitty & Helpers
alias kittyconf='${EDITOR:-nano} "$XDG_CONFIG_HOME/kitty/kitty.conf"'
alias reloadkitty='kill -SIGUSR1 $KITTY_PID'
alias img='kitty +kitten icat'
alias kittyupdate='curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin'

# Section: Safety
alias rm='rm -I'
alias cp='cp -i'
alias mv='mv -i'
alias rem='rm -rI'

function clear-history() {
    local state="${XDG_STATE_HOME:-$HOME/.local/state}"
    clear && echo "Wiping history..."
    rm -f ~/.bash_history ~/.zsh_history "$state/bash/history" "$state/zsh/history"
    [ -n "$ZSH_VERSION" ] && fc -p || history -c
    echo "Done."
}

# Section: Package Manager
alias s='apt search'
alias i='sudo apt install'
alias u='sudo apt update && sudo apt upgrade -y'
alias r='sudo apt remove --purge'
alias ar='sudo apt autoremove'

# Section: Functions
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

function fr() {
    local file
    file=$(rg --files --hidden --glob "!.git/*" | fzf)
    [ -n "$file" ] && ${EDITOR:-nano} "$file"
}
