# Shared Aliases

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Zoxide (cd)
if command -v zoxide &> /dev/null; then
    alias cd='z'
    alias cdi='zi'
fi

# Listing (eza)
if command -v eza &> /dev/null; then
    alias ls='eza --color=auto --icons=always --group-directories-first'
    alias ll='eza -alF --color=auto --icons=always --group-directories-first'
    alias la='eza -A --color=auto --icons=always --group-directories-first'
    alias l='eza -CF --color=auto --icons=always --group-directories-first'
else
    alias ls='ls --color=auto'
    alias ll='ls -alF --color=auto'
    alias la='ls -A --color=auto'
    alias l='ls -CF --color=auto'
fi

# Search
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Shortcuts
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

alias c='clear'
alias cls='clear'
alias h='history'
alias nf='neofetch'
alias helium='( /home/omar/AppImages/helium.appimage >/dev/null 2>&1 & )'

# Cleanup
alias rem='rm -rI'
function clear-history() {
    local state="${XDG_STATE_HOME:-$HOME/.local/state}"
    clear && echo "Wiping history..."
    rm -f ~/.bash_history ~/.zsh_history "$state/bash/history" "$state/zsh/history"
    [ -n "$ZSH_VERSION" ] && fc -p || history -c
    echo "Done."
}

# Bat (cat)
if command -v batcat &> /dev/null; then
    alias bat='batcat'
    alias cat='batcat'
    alias catp='batcat -p'
elif command -v bat &> /dev/null; then
    alias bat='bat'
    alias cat='bat'
    alias catp='bat -p'
fi

# Safety
alias rm='rm -I'
alias cp='cp -i'
alias mv='mv -i'

# Tool Configs
alias kittyconf='${EDITOR:-nano} "$XDG_CONFIG_HOME/kitty/kitty.conf"'
alias reloadkitty='kill -SIGUSR1 $KITTY_PID'
alias kittyupdate='curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin launch=n'
alias img='kitty +kitten icat'

# Package Manager
alias s='apt search'
alias i='sudo apt install'
alias u='sudo apt update && sudo apt upgrade -y'
alias r='sudo apt remove --purge'
alias ar='sudo apt autoremove'

# Git
alias g='git'
alias ga='git add'
alias gc='git commit -m'
alias gp='git push'
alias gl='git pull'
alias gst='git status'
alias gd='git diff'

# System
alias df='df -h'
alias free='free -m'
alias ports='netstat -tulanp'
alias myip='curl -s https://ifconfig.me && echo'
alias killport='fuser -k -n tcp'
alias sync='~/Dev/dotfiles/linux/install.sh'
